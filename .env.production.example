# ── Production VPS — https://scalping.optionperks.com ──
# Copy to .env on server:  cp .env.production.example .env

# Domain & TLS (Caddy auto-issues Let's Encrypt cert)
DOMAIN=scalping.optionperks.com
ACME_EMAIL=you@example.com

# App secrets — CHANGE ALL BEFORE DEPLOY
SECRET_KEY=generate-a-long-random-string-min-32-chars
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ENVIRONMENT=production
CORS_ORIGINS=https://scalping.optionperks.com

# Database (internal Docker network — do not expose ports)
POSTGRES_USER=scalpdesk
POSTGRES_PASSWORD=change-strong-db-password
POSTGRES_DB=scalpdesk

# Redis (internal)
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Kite Connect callback (must match Zerodha app settings)
KITE_REDIRECT_URL=https://scalping.optionperks.com/api/accounts/callback

# Frontend build args (baked into static bundle at build time)
VITE_API_URL=https://scalping.optionperks.com/api
VITE_WS_URL=wss://scalping.optionperks.com/api

# Scheduler (IST)
MARKET_OPEN_LOGIN_TIME=08:45
INSTRUMENT_SYNC_TIME=08:50
EOD_SQUAREOFF_TIME=15:20
TIMEZONE=Asia/Kolkata

KITE_INSTRUMENTS_URL=https://api.kite.trade/instruments
INSTRUMENT_SYNC_BATCH_SIZE=1000
DEFAULT_PAPER_MODE=true
