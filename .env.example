# App
SECRET_KEY=change-me-to-a-long-random-string
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (host URL only if running backend outside Docker)
POSTGRES_USER=scalpdesk
POSTGRES_PASSWORD=scalpdesk
POSTGRES_DB=scalpdesk
# For local backend: use host port if you map postgres (e.g. 5433:5432 in compose)
DATABASE_URL=postgresql+asyncpg://scalpdesk:scalpdesk@localhost:5432/scalpdesk

# Redis (host URL only if running backend outside Docker)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Kite Connect (per-account creds stored encrypted in DB)
KITE_REDIRECT_URL=http://localhost:8000/accounts/callback

# Zerodha enctoken (optional — per-account creds stored encrypted in DB)
# ZERODHA_USER_ID=
# ZERODHA_PASSWORD=

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Production VPS — see .env.production.example (domain: scalping.optionperks.com)

# Scheduler (IST)
MARKET_OPEN_LOGIN_TIME=08:45
INSTRUMENT_SYNC_TIME=08:50
EOD_SQUAREOFF_TIME=15:20
TIMEZONE=Asia/Kolkata

# Kite instrument master (public CSV — no auth required)
KITE_INSTRUMENTS_URL=https://api.kite.trade/instruments
INSTRUMENT_SYNC_BATCH_SIZE=1000

# Defaults
DEFAULT_PAPER_MODE=true
